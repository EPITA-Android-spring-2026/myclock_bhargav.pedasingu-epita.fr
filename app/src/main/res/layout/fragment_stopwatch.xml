<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_stopwatch.xml
    ----------------------
    Shows elapsed time in MM:SS.cc format.
    Buttons: Start/Pause, Reset, Lap.
    Scrollable list of lap times at the bottom.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FAFAFA"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Stopwatch"
        android:textSize="20sp"
        android:textColor="#6200EE"
        android:textStyle="bold"
        android:paddingBottom="32dp"/>

    <!-- Main time display -->
    <TextView
        android:id="@+id/stopwatch_display"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="00:00.00"
        android:textSize="72sp"
        android:textColor="#1A1A2E"
        android:gravity="center"
        android:fontFamily="monospace"
        android:paddingBottom="32dp"/>

    <!-- Control buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingBottom="20dp">

        <Button
            android:id="@+id/start_stop_button"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="Start"
            android:textColor="#FFFFFF"
            android:backgroundTint="#4CAF50"
            android:textSize="16sp"/>

        <Button
            android:id="@+id/lap_button"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp"
            android:text="Lap"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2196F3"
            android:textSize="16sp"
            android:enabled="false"/>

        <Button
            android:id="@+id/stopwatch_reset_button"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="Reset"
            android:textColor="#FFFFFF"
            android:backgroundTint="#F44336"
            android:textSize="16sp"/>

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Lap Times"
        android:textSize="15sp"
        android:textColor="#555555"
        android:textStyle="bold"
        android:paddingBottom="8dp"/>

    <!-- Scrollable lap list -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/lap_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"/>

    </ScrollView>

</LinearLayout>
